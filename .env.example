# TokoKit Environment Variables
# Copy this file to .env for local development
# NEVER commit .env to version control

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Storage bucket name (should match your Supabase bucket)
STORAGE_BUCKET=tokokit-assets

# ============================================
# Public Site Configuration
# ============================================
# Your public site URL (for redirects, emails, etc.)
PUBLIC_SITE_URL=http://localhost:8080

# Admin contact information
ADMIN_WHATSAPP=
ADMIN_EMAIL=admin@yourdomain.com

# Demo store slug (for landing page)
DEMO_STORE_SLUG=demo-store

# ============================================
# Payment Gateway - Midtrans
# ============================================
# Get from: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ============================================
# Payment Gateway - Xendit
# ============================================
# Get from: https://dashboard.xendit.co/settings/developers
XENDIT_SECRET_KEY=
XENDIT_PUBLIC_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_WEBHOOK_SECRET=

# ============================================
# Payment Gateway - Custom/Generic
# ============================================
# For custom payment gateway webhooks
TOKOKIT_GATEWAY_WEBHOOK_SECRET=generate-a-random-secret-here

# ============================================
# Email Service (Resend)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=TokoKit <noreply@yourdomain.com>

# ============================================
# Monitoring & Analytics
# ============================================
# Sentry for error tracking
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog for analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ============================================
# Security
# ============================================
# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-session-secret-here

# ============================================
# Redis (Optional - for caching)
# ============================================
REDIS_URL=
REDIS_TOKEN=

# ============================================
# Feature Flags
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PAYMENT_GATEWAYS=true
ENABLE_EMAIL_DELIVERY=true
ENABLE_ANALYTICS=true

# ============================================
# Development
# ============================================
NODE_ENV=development
LOG_LEVEL=info
